# Preview Environment Configuration
# Use these variables for Vercel Preview deployments (pull requests, staging branches)
# Configure in Vercel dashboard → Settings → Environment Variables → Select "Preview" environment

# API Configuration - Point to staging/preview backend
EXPO_PUBLIC_API_URL=https://api-staging.nexus-portal.example.com

# Environment Configuration
EXPO_PUBLIC_APP_ENV=preview
EXPO_PUBLIC_TENANT_MODE=multi

# Error Tracking - Optional for preview, but recommended
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Note: Preview deployments are used for:
# - Pull request previews (temporary)
# - Staging branch deployments
# - Pre-production testing
# 
# Set these in Vercel for "Preview" environment scope only
